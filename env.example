# .env.example — copy to .env and fill in values
# DO NOT commit .env to version control.
# Ensure .env is in your .gitignore.

# --- LLM / AI Providers ---
GOOGLE_API_KEY=your_google_api_key_here

# --- Document Parser (PaddleOCR-VL) ---
# Set to True to skip source checks for local Paddle models
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=True

# --- VLM Backend Configuration ---
# Options: "local" (Paddle-based) or "external" (vLLM/OpenAI-compatible)
VLM_BACKEND=local
VLM_SERVER_URL=http://localhost:8000/v1
VLM_API_KEY=not_needed_for_local
VLM_API_MODEL_NAME=PaddlePaddle/PaddleOCR-VL-1.5

# --- Vector DB (Qdrant) ---
QDRANT_URL=http://localhost:6333

# --- Cache / State (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Retrieval Settings ---
COLLECTION_BASE_NAME=secure_rag
EMBED_MODEL_NAME=BAAI/bge-small-en-v1.5
